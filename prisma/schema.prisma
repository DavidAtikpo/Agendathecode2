generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["agenda"]
}

model User {
  id                   String        @id @default(cuid())
  email                String        @unique
  /// Null si le compte est uniquement « Connexion Google »
  passwordHash         String?
  name                 String
  color                String
  initials             String
  createdAt            DateTime      @default(now())
  /// Identifiant unique Google (sub)
  googleId             String?       @unique
  plan                 Plan          @default(free)
  stripeCustomerId     String?       @unique
  stripeSubscriptionId String?       @unique
  /// Fin de période payée (affichage / grâce)
  subscriptionEndsAt   DateTime?
  /// Préférences UI / produit (JSON — voir `user-preferences.ts` côté app)
  preferences          Json             @default("{}")
  notes                Note[]
  tasksAssigned        Task[]        @relation("AssignedTo")
  tasksCreated         Task[]        @relation("CreatedBy")
  teamContactsAsMember TeamContact[] @relation("TeamContactMember")
  teamContactsAdded    TeamContact[] @relation("TeamContactOwner")
  noteSharesReceived   NoteShare[]   @relation("NoteShareWith")

  @@schema("agenda")
}

/// Lien « j’ai ajouté ce collègue par email » — seuls ces membres sont assignables aux tâches.
model TeamContact {
  id        String   @id @default(cuid())
  ownerId   String
  memberId  String
  createdAt DateTime @default(now())
  member    User     @relation("TeamContactMember", fields: [memberId], references: [id], onDelete: Cascade)
  owner     User     @relation("TeamContactOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, memberId])
  @@index([ownerId])
  @@schema("agenda")
}

model Note {
  id                  String    @id @default(cuid())
  title               String
  content             String    @default("")
  pinned              Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  /// Date/heure du rappel (optionnel)
  remindAt            DateTime?
  /// Envoyer un e-mail automatique à l’heure du rappel (compte connecté uniquement)
  reminderByEmail     Boolean   @default(true)
  /// Horodatage d’envoi réussi (évite les doublons)
  reminderEmailSentAt DateTime?
  userId              String?
  user                User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  shares              NoteShare[]

  @@index([userId])
  @@index([remindAt])
  @@schema("agenda")
}

/// Partage lecture d’une note avec un collaborateur (lien TeamContact propriétaire → membre).
model NoteShare {
  id        String   @id @default(cuid())
  noteId    String
  userId    String
  createdAt DateTime @default(now())
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user      User     @relation("NoteShareWith", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([noteId, userId])
  @@index([noteId])
  @@index([userId])
  @@schema("agenda")
}

model Task {
  id           String       @id @default(cuid())
  title        String
  description  String       @default("")
  status       TaskStatus   @default(todo)
  priority     TaskPriority @default(medium)
  dueDate      DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  assignedToId String?
  createdById  String
  /// Horodatage « ping » assignation : l’assigné voit un badge jusqu’à ouverture de la vue Tâches.
  assigneeNotifiedAt DateTime?
  assignedTo         User?        @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdBy          User         @relation("CreatedBy", fields: [createdById], references: [id])

  @@index([assignedToId])
  @@schema("agenda")
}

enum TaskStatus {
  todo
  /// Bugs et tâches à traiter immédiatement (hors file normale).
  urgent
  doing
  done
  review

  @@schema("agenda")
}

enum TaskPriority {
  low
  medium
  high
  urgent

  @@schema("agenda")
}

enum Plan {
  free
  pro

  @@schema("agenda")
}
