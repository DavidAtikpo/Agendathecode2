generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["agenda"]
}

model User {
  id                   String           @id @default(cuid())
  email                String           @unique
  /// Null si le compte est uniquement « Connexion Google »
  passwordHash         String?
  name                 String
  color                String
  initials             String
  createdAt            DateTime         @default(now())
  /// Identifiant unique Google (sub)
  googleId             String?          @unique
  plan                 Plan             @default(free)
  role                 Role             @default(user)
  stripeCustomerId     String?          @unique
  stripeSubscriptionId String?          @unique
  /// Fin de période payée (affichage / grâce)
  subscriptionEndsAt   DateTime?
  /// Préférences UI / produit (JSON — voir `user-preferences.ts` côté app)
  preferences          Json             @default("{}")
  /// false = compte suspendu par un admin (connexion refusée)
  active               Boolean          @default(true)
  /// Crédits IA restants (1 crédit = 1 message Claude)
  aiCredits            Int              @default(0)
  /// Date d'expiration des crédits (1 an après l'achat)
  aiCreditsExpiresAt   DateTime?
  /// Nombre de notifications push envoyées non vues — badge de l'icône app mobile.
  unreadNotificationCount Int           @default(0)
  notes                Note[]
  taskAssignments      TaskAssignment[]
  taskAssetsUploaded   TaskAsset[]
  tasksCreated         Task[]           @relation("CreatedBy")
  teamContactsAsMember TeamContact[]    @relation("TeamContactMember")
  teamContactsAdded    TeamContact[]    @relation("TeamContactOwner")
  noteSharesReceived   NoteShare[]      @relation("NoteShareWith")
  noteAssetsUploaded   NoteAsset[]
  taskComments         TaskComment[]
  deviceTokens         DeviceToken[]
  groupsCreated        Group[]          @relation("GroupCreator")
  groupMemberships     GroupMember[]
  trainingSessionsCreated TrainingSession[] @relation("TrainingSessionCreator")
  sessionAssignments   SessionAssignment[]
  passwordResetTokens  PasswordResetToken[]
  /// Organisateur (ou admin) ayant créé ce compte formateur / assessor / auditeur
  staffCreatedById     String?
  staffCreatedBy       User?            @relation("StaffAccountCreator", fields: [staffCreatedById], references: [id], onDelete: SetNull)
  staffAccountsCreated User[]           @relation("StaffAccountCreator")
  staffRegistration    StaffRegistration? @relation("StaffRegistrationStaff")
  staffRegistrationsCreated StaffRegistration[] @relation("StaffRegistrationCreator")

  @@index([staffCreatedById])
  @@schema("agenda")
}

/// Lien organisateur → intervenant créé (source de vérité pour la liste confidentielle).
model StaffRegistration {
  staffUserId String   @id
  createdById String
  createdAt   DateTime @default(now())
  staff       User     @relation("StaffRegistrationStaff", fields: [staffUserId], references: [id], onDelete: Cascade)
  creator     User     @relation("StaffRegistrationCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([createdById])
  @@schema("agenda")
}

/// Jeton à usage unique pour réinitialiser le mot de passe (hash SHA-256 en base).
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@schema("agenda")
}

/// Token FCM par appareil — permet d'envoyer des notifications push.
model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   @default("android")
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@schema("agenda")
}

/// Lien « j’ai ajouté ce collègue par email » — seuls ces membres sont assignables aux tâches.
model TeamContact {
  id        String   @id @default(cuid())
  ownerId   String
  memberId  String
  createdAt DateTime @default(now())
  member    User     @relation("TeamContactMember", fields: [memberId], references: [id], onDelete: Cascade)
  owner     User     @relation("TeamContactOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, memberId])
  @@index([ownerId])
  @@schema("agenda")
}

/// Groupe de collaborateurs — tâches partagées visibles par tous les membres.
model Group {
  id           String        @id @default(cuid())
  name         String
  logoUrl      String?
  logoPublicId String?
  createdById  String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  createdBy    User          @relation("GroupCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members      GroupMember[]
  tasks        Task[]

  @@index([createdById])
  @@schema("agenda")
}

model GroupMember {
  groupId  String
  userId   String
  joinedAt DateTime @default(now())
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@index([userId])
  @@schema("agenda")
}

model Note {
  id                  String      @id @default(cuid())
  title               String
  content             String      @default("")
  pinned              Boolean     @default(false)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  /// Date/heure du rappel (optionnel)
  remindAt            DateTime?
  /// Envoyer un e-mail automatique à l’heure du rappel (compte connecté uniquement)
  reminderByEmail     Boolean     @default(true)
  /// Horodatage d’envoi réussi (évite les doublons)
  reminderEmailSentAt DateTime?
  userId              String?
  user                User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  shares              NoteShare[]
  assets              NoteAsset[]

  @@index([userId])
  @@index([remindAt])
  @@schema("agenda")
}

/// Photos, captures et documents joints à une note (stockés sur Cloudinary).
model NoteAsset {
  id           String   @id @default(cuid())
  noteId       String
  uploaderId   String
  mediaType    String
  originalName String
  bytes        Int?
  url          String
  publicId     String
  createdAt    DateTime @default(now())
  note         Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  uploader     User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)

  @@index([noteId, createdAt])
  @@schema("agenda")
}

/// Partage lecture d’une note avec un collaborateur (lien TeamContact propriétaire → membre).
model NoteShare {
  id        String   @id @default(cuid())
  noteId    String
  userId    String
  createdAt DateTime @default(now())
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user      User     @relation("NoteShareWith", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([noteId, userId])
  @@index([noteId])
  @@index([userId])
  @@schema("agenda")
}

model Task {
  id                 String           @id @default(cuid())
  title              String
  description        String           @default("")
  status             TaskStatus       @default(todo)
  priority           TaskPriority     @default(medium)
  dueDate            DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  createdById        String
  /// Horodatage « ping » assignation : l’assigné voit un badge jusqu’à ouverture de la vue Tâches.
  assigneeNotifiedAt DateTime?
  /// Groupe partagé — tous les membres voient la tâche (lecture + commentaires).
  groupId            String?
  assignees          TaskAssignment[]
  assets             TaskAsset[]
  comments           TaskComment[]
  createdBy          User             @relation("CreatedBy", fields: [createdById], references: [id])
  group              Group?           @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@index([groupId])
  @@schema("agenda")
}

/// Message de discussion lié à une tâche (visible par le créateur et les assignés).
model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@schema("agenda")
}

model TaskAsset {
  id           String        @id @default(cuid())
  taskId       String
  uploaderId   String
  kind         TaskAssetKind
  mediaType    String
  originalName String
  bytes        Int?
  url          String
  publicId     String
  createdAt    DateTime      @default(now())
  task         Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploader     User          @relation(fields: [uploaderId], references: [id], onDelete: Cascade)

  @@index([taskId, kind, createdAt])
  @@schema("agenda")
}

enum TaskAssetKind {
  input
  output

  @@schema("agenda")
}

model TaskAssignment {
  taskId     String
  userId     String
  assignedAt DateTime @default(now())
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@index([userId])
  @@schema("agenda")
}

enum TaskStatus {
  todo
  /// Bugs et tâches à traiter immédiatement (hors file normale).
  urgent
  doing
  testing
  done
  review

  @@schema("agenda")
}

enum TaskPriority {
  low
  medium
  high
  urgent

  @@schema("agenda")
}

enum Plan {
  free
  pro

  @@schema("agenda")
}

enum Role {
  user
  admin
  /// Crée et gère les sessions formation (formateurs / assessors).
  organizer
  /// Reçoit les propositions de session — pas d’accès aux groupes.
  formateur
  /// Reçoit les propositions de session — pas d’accès aux groupes.
  assessor
  /// Auditeur / stagiaire observateur — compte créé par organisateur ou admin.
  auditeur

  @@schema("agenda")
}

/// Session de formation — créée par un utilisateur Organisateur (rôle `organizer`).
model TrainingSession {
  id          String              @id @default(cuid())
  title       String
  startDate   DateTime            @db.Date
  endDate     DateTime            @db.Date
  /// Option B — deuxième plage de dates proposée (début).
  altStartDate DateTime?          @db.Date
  /// Option B — deuxième plage de dates proposée (fin).
  altEndDate   DateTime?          @db.Date
  examDate    DateTime?           @db.Date
  createdById String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  createdBy   User                @relation("TrainingSessionCreator", fields: [createdById], references: [id], onDelete: Cascade)
  assignments SessionAssignment[]

  @@index([createdById])
  @@index([startDate])
  @@schema("agenda")
}

/// Proposition formateur / assessor — validation indépendante par rôle.
model SessionAssignment {
  id          String                  @id @default(cuid())
  sessionId   String
  userId      String
  role        SessionAssignmentRole
  status      SessionAssignmentStatus   @default(pending)
  /// Plage acceptée quand deux options sont proposées (primary = option A).
  acceptedOption SessionDateOption?
  respondedAt DateTime?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  session     TrainingSession         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, role])
  @@index([userId])
  @@index([sessionId])
  @@schema("agenda")
}

enum SessionAssignmentRole {
  formateur
  assessor

  @@schema("agenda")
}

enum SessionAssignmentStatus {
  pending
  accepted
  declined

  @@schema("agenda")
}

enum SessionDateOption {
  primary
  alternative

  @@schema("agenda")
}
